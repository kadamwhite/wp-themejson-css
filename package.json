{
  "name": "wp-themejson-css",
  "displayName": "wp-themejson-css",
  "description": "Highlight CSS strings inside WordPress theme.json files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wpThemeJsonCss.editInlineCss",
        "title": "WP: Edit inline CSS"
      }
    ],
    "grammars": [
      {
        "scopeName": "wp.themejson.css.injection",
        "path": "./syntaxes/wp-themejson-css-injection.tmLanguage.json",
        "injectTo": [
          "source.json",
          "source.json.comments"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  }
}
