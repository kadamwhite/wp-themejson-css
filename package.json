{
  "name": "wp-themejson-css",
  "displayName": "wp-themejson-css",
  "publisher": "humanmade",
  "description": "Highlight CSS strings inside WordPress theme.json files",
  "version": "1.0.0",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/humanmade/wp-themejson-css.git"
  },
  "bugs": {
    "url": "https://github.com/humanmade/wp-themejson-css/issues"
  },
  "homepage": "https://github.com/humanmade/wp-themejson-css#readme",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wpThemeJsonCss.editInlineCss",
        "title": "WP: Edit inline theme.json CSS"
      }
    ],
    "configuration": {
      "title": "WP theme.json Inline CSS",
      "properties": {
        "wpThemeJsonCss.sortDeclarations": {
          "type": "boolean",
          "default": false,
          "description": "Alphabetically sort CSS declarations when minifying back into theme.json."
        }
      }
    },
    "grammars": [
      {
        "scopeName": "wp.themejson.css.injection",
        "path": "./syntaxes/wp-themejson-css-injection.tmLanguage.json",
        "injectTo": [
          "source.json",
          "source.json.comments"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "cssnano": "^7.1.2",
    "jsonc-parser": "^3.3.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1"
  }
}
